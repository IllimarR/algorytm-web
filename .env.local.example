# Captivate.fm RSS feed (public, no auth required)
# Find this URL in Captivate.fm → your show → Distribution → RSS feed
CAPTIVATE_RSS_URL=https://feeds.captivate.fm/your-show-slug/

# Captivate.fm REST API credentials (for future private data access)
# Find these in your Captivate.fm account settings
CAPTIVATE_API_USER=your_email@example.com
CAPTIVATE_API_KEY=your_api_key_here
CAPTIVATE_SHOW_ID=your_show_id_here
